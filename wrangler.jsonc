{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "getitmart",
  "compatibility_date": "2026-05-19",
  "compatibility_flags": ["nodejs_compat"],
  "main": "./dist/server/index.js",
  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}